# Copy to `.env` (gitignored) and fill in. All EXPO_PUBLIC_* vars are inlined
# into the JS bundle at build time, so put PUBLIC client IDs only — never the
# Google client secret (that lives in the Supabase Dashboard) or a service key.

# --- Supabase ---
# Optional: src/integrations/supabase/env.ts ships working dev fallbacks that
# point at the SAME project/anon key as the web app (rbtdkdbmtecungdthujf), so
# the app boots without these. Set them only to target a different project.
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=

# --- Google Sign-In (Android — current target) ---
# REQUIRED. The Web OAuth client ID configured on the Supabase Dashboard's
# Google provider (Authentication -> Providers -> Google) for project
# rbtdkdbmtecungdthujf. Android signs the ID token, but its audience is this
# Web client, and Supabase verifies against it. Same value the web app uses.
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=
# (Android also needs an Android OAuth client in Google Cloud: package
#  com.anonymous.safarlymobile + the signing SHA-1. No env var for it — Google
#  resolves it from the signing certificate.)

# --- Google Sign-In (iOS — deferred, not needed for Android) ---
# Wire these when iOS is picked up; you must also re-add the
# @react-native-google-signin/google-signin config plugin (iosUrlScheme).
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_IOS_URL_SCHEME=
